  "claim-llm-functional-introspection" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm functional\nintrospection", tooltip="Some current LLMs exhibit limited, unreliable functional introspective awareness of their internal states", URL="../web/claims/llm-functional-introspection.md"];
  "claim-llm-has-mental-states" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm has mental\nstates", tooltip="Some current LLMs realise some mental states", URL="../web/claims/llm-has-mental-states.md"];
  "claim-lookup-table-combinatorially-inadequate" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table\ncombinatorially\ninadequate", tooltip="No finite lookup table can reproduce the full behavioural profile of a genuine mind", URL="../web/claims/lookup-table-combinatorially-inadequate.md"];
  "claim-lookup-table-lacks-mind" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table lacks\nmind", tooltip="A system that produces behaviour solely by stored lookup has no mental states", URL="../web/claims/lookup-table-lacks-mind.md"];
  "claim-lookup-table-physically-unrealisable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table\nphysically\nunrealisable", tooltip="A lookup table reproducing a human- or LLM-scale behavioural profile is physically unrealisable", URL="../web/claims/lookup-table-physically-unrealisable.md"];
  "claim-lookup-table-possible" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table\npossible", tooltip="A lookup table can reproduce a mind's behavioural profile without any internal causal organisation", URL="../web/claims/lookup-table-possible.md"];
  "claim-lookup-table-size-exponential" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table size\nexponential", tooltip="A lookup table reproducing behaviour over a context of n tokens from a vocabulary of v requires on the order of v^n entries", URL="../web/claims/lookup-table-size-exponential.md"];
  "claim-mind-handles-unbounded-inputs" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mind handles\nunbounded inputs", tooltip="A genuine mind can respond appropriately to novel inputs beyond any fixed finite stock", URL="../web/claims/mind-handles-unbounded-inputs.md"];
  "claim-no-acquaintance-with-machine" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="no acquaintance\nwith machine", tooltip="One has no first-person acquaintance with a machine's putative experience", URL="../web/claims/no-acquaintance-with-machine.md"];
  "claim-observable-universe-finite-storage" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="observable\nuniverse finite\nstorage", tooltip="The observable universe can store only a bounded, finite amount of information (on the order of 10^120 bits)", URL="../web/claims/observable-universe-finite-storage.md"];
  "claim-organisational-grain-faces-own-grain-dilemma" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="organisational\ngrain faces own\ngrain dilemma", tooltip="The organisational-role grain either readmits the blockhead or smuggles sub-organisational features back in", URL="../web/claims/organisational-grain-faces-own-grain-dilemma.md"];
  "claim-personal-identity-admits-of-degree" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="personal identity\nadmits of degree", tooltip="Personal identity is not all-or-nothing but admits of degree", URL="../web/claims/personal-identity-admits-of-degree.md"];
  "claim-phenomenal-concept-isolation-tradeoff" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal concept\nisolation tradeoff", tooltip="A phenomenal concept cannot be at once informative enough to ground self-knowledge while isolated enough to deflate the explanatory gap", URL="../web/claims/phenomenal-concept-isolation-tradeoff.md"];
  "claim-phenomenal-determinacy" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal\ndeterminacy", tooltip="There is a determinate fact about one's own current phenomenal state", URL="../web/claims/phenomenal-determinacy.md"];
  "claim-phenomenal-residue" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal residue", tooltip="Phenomenally conscious states are not exhausted by functional/causal role", URL="../web/claims/phenomenal-states-not-exhausted-by-role.md"];
