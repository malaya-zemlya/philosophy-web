  "claim-access-grounds-no-asymmetry" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="access grounds no\nasymmetry", tooltip="First-person access grounds no moral-status asymmetry that singles out machines", URL="../web/claims/access-grounds-no-asymmetry.md"];
