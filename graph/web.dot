  "claim-sorites-tolerance" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="sorites tolerance", tooltip="Removing a single grain from a heap always leaves a heap", URL="../web/claims/sorites-tolerance.md"];
