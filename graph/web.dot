  "argument-rejoinder-trivializes-strong-ai" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="rejoinder\ntrivializes strong\nai", tooltip="Many Mansions trivialises strong AI — the reply concedes the thesis it was meant to save", URL="../web/arguments/rejoinder-trivializes-strong-ai.md"];
  "argument-rejoinder-water-pipes" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="rejoinder water\npipes", tooltip="The water-pipe brain — simulating the form of neural firing reproduces structure, not causal power", URL="../web/arguments/rejoinder-water-pipes.md"];
  "argument-relevance-filter-regress" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="relevance filter\nregress", tooltip="The relevance-filter regress — selecting mind-relevant causal relations re-raises the invariant demand", URL="../web/arguments/relevance-filter-regress.md"];
  "argument-report-scepticism-proves-too-much" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="report scepticism\nproves too much", tooltip="Report-scepticism proves too much — applied uniformly, its discount rules screen off human hard-problem reports as well", URL="../web/arguments/report-scepticism-proves-too-much.md"];
