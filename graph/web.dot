  "claim-posing-the-gap-requires-access" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="posing the gap\nrequires access", tooltip="Formulating the hard problem from the first-person side requires access to a representation of one's own phenomenal-seeming states", URL="../web/claims/posing-the-gap-requires-access.md"];
  "claim-privileged-first-person-access" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="privileged first\nperson access", tooltip="Each subject has direct, non-inferential first-person acquaintance with its own conscious states", URL="../web/claims/privileged-first-person-access.md"];
  "claim-prudence-favors-flesh-criterion" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="prudence favors\nflesh criterion", tooltip="Prudence favours resting moral standing on currently-unforgeable biology rather than on forgeable behavioural signs", URL="../web/claims/prudence-favors-flesh-criterion.md"];
  "claim-psychological-rewiring-tolerance" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="psychological\nrewiring tolerance", tooltip="Altering a single psychological connection never changes who someone is", URL="../web/claims/psychological-rewiring-tolerance.md"];
