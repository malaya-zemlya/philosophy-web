  "claim-self-model-is-part-of-state" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="self model is part\nof state", tooltip="A finite system's self-representation is part of the very state it represents", URL="../web/claims/self-model-is-part-of-state.md"];
