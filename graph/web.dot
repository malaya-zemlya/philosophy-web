  "argument-rejoinder-internalize-rulebook" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="rejoinder\ninternalize\nrulebook", tooltip="Internalise the rulebook — the person becomes the whole system and still understands nothing", URL="../web/arguments/rejoinder-internalize-rulebook.md"];
