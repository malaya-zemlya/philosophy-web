  "argument-acquaintance-hypothesis" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="acquaintance\nhypothesis", tooltip="The Acquaintance Hypothesis — Mary meets the experience rather than learning a truth", URL="../web/arguments/acquaintance-hypothesis.md"];
  "argument-ai-hard-problem-from-self-model-architecture" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="ai hard problem\nfrom self model\narchitecture", tooltip="Self-model architecture predicts an advanced LLM will exhibit its own hard-problem form", URL="../web/arguments/ai-hard-problem-from-self-model-architecture.md"];
  "argument-aoe2-anthropomorphism" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="aoe2\nanthropomorphism", tooltip="If LLMs have human-like attributes, then so does Age of Empires II", URL="../web/arguments/aoe2-anthropomorphism.md"];
  "argument-architectural-account-leaves-hard-problem" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="architectural\naccount leaves\nhard problem", tooltip="The architectural account explains an access gap, not the phenomenal one", URL="../web/arguments/architectural-account-leaves-hard-problem.md"];
  "argument-behavioral-parity" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="behavioral parity", tooltip="Behavioural parity is evidence of mental status", URL="../web/arguments/behavioral-parity.md"];
  "argument-bike-rider-learns-facts" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="bike rider learns\nfacts", tooltip="The bike rider learns facts — the ability hypothesis rests on a false dichotomy", URL="../web/arguments/bike-rider-learns-facts.md"];
  "argument-blockhead-dilemma" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="blockhead dilemma", tooltip="The blockhead dilemma — physically impossible, or imaginatively under-determined", URL="../web/arguments/blockhead-dilemma.md"];
  "argument-bounded-table-rejoinder" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="bounded table\nrejoinder", tooltip="Block's bounded-table rejoinder — a lifetime-bounded table escapes the combinatorial reply", URL="../web/arguments/bounded-table-rejoinder.md"];
  "argument-brain-simulator-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="brain simulator\nreply", tooltip="The Brain Simulator Reply — simulate the neuron firings of a real Chinese speaker", URL="../web/arguments/brain-simulator-reply.md"];
  "argument-causal-argument-for-physicalism" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="causal argument\nfor physicalism", tooltip="The causal argument for physicalism", URL="../web/arguments/causal-argument-for-physicalism.md"];
  "argument-causal-exclusion" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="causal exclusion", tooltip="Kim's causal exclusion (supervenience) argument", URL="../web/arguments/causal-exclusion.md"];
  "argument-causal-structure-supplies-invariant" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="causal structure\nsupplies invariant", tooltip="The causal-structure reply — objective counterfactual structure supplies the invariant", URL="../web/arguments/causal-structure-supplies-invariant.md"];
  "argument-china-nation-absent-qualia" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="china nation\nabsent qualia", tooltip="The Chinese Nation realises the organisation yet lacks qualia — organisation is not sufficient for consciousness", URL="../web/arguments/china-nation-absent-qualia.md"];
  "argument-chinese-room" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="chinese room", tooltip="The Chinese Room — running a program is not sufficient for understanding", URL="../web/arguments/chinese-room.md"];
  "argument-chinese-room-derivation" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="chinese room\nderivation", tooltip="The Chinese Room as a derivation from axioms — syntax is not sufficient for minds", URL="../web/arguments/chinese-room-derivation.md"];
  "argument-cognitive-closure" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="cognitive closure", tooltip="McGinn's cognitive-closure argument for mysterianism", URL="../web/arguments/cognitive-closure.md"];
  "argument-combination-problem" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="combination\nproblem", tooltip="The combination problem — micro-subjects cannot compose a macro-subject", URL="../web/arguments/combination-problem.md"];
  "argument-conceivability-not-guide-to-possibility" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="conceivability not\nguide to\npossibility", tooltip="Conceivability is not a reliable guide to possibility (the a-posteriori-necessity objection)", URL="../web/arguments/conceivability-not-guide-to-possibility.md"];
  "argument-conceivable-not-physically-realizable" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="conceivable not\nphysically\nrealizable", tooltip="The halting oracle shows conceivability does not entail physical realizability", URL="../web/arguments/conceivable-not-physically-realizable.md"];
  "argument-connectionist-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="connectionist\nreply", tooltip="The Connectionist Reply — a massively parallel, brain-like architecture is the real candidate for understanding", URL="../web/arguments/connectionist-reply.md"];
  "argument-contaminated-testimony-carries-no-weight" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="contaminated\ntestimony carries\nno weight", tooltip="A consciousness-corpus-trained model's hard-problem testimony carries zero evidential weight, not reduced weight", URL="../web/arguments/contaminated-testimony-carries-no-weight.md"];
  "argument-counterfactuals-yield-non-triviality-not-uniqueness" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="counterfactuals\nyield non\ntriviality not\nuniqueness", tooltip="Counterfactuals buy non-triviality, not uniqueness", URL="../web/arguments/counterfactuals-yield-non-triviality-not-uniqueness.md"];
  "argument-dancing-qualia" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="dancing qualia", tooltip="Dancing qualia — a functional isomorph with inverted qualia would have its experience flip undetectably, which is absurd", URL="../web/arguments/dancing-qualia.md"];
  "argument-dancing-qualia-begs-the-question" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="dancing qualia\nbegs the question", tooltip="The dancing/fading-qualia reductio begs the question by presupposing functionalism about introspection", URL="../web/arguments/dancing-qualia-begs-the-question.md"];
  "argument-dancing-qualia-no-memory-trace" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="dancing qualia no\nmemory trace", tooltip="The dance leaves no memory trace — \"noticing\" a qualia flip needs a cross-time comparison whose earlier term is functionally fixed", URL="../web/arguments/dancing-qualia-no-memory-trace.md"];
  "argument-de-novo-origination-breaks-report-parity" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="de novo\norigination breaks\nreport parity", tooltip="De novo human origination breaks the report-scepticism parity — the contamination rule's trigger is met for AI and unmet for the human originators", URL="../web/arguments/de-novo-origination-breaks-report-parity.md"];
  "argument-decomposition-indeterminacy" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="decomposition\nindeterminacy", tooltip="The decomposition-indeterminacy objection — determinate consciousness cannot rest on observer-relative function", URL="../web/arguments/decomposition-indeterminacy.md"];
  "argument-dense-china-brain-regress" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="dense china brain\nregress", tooltip="The dense China-brain regress reopens the grain dilemma against the organisational middle", URL="../web/arguments/dense-china-brain-regress.md"];
  "argument-deutsch-anti-solipsism" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="deutsch anti\nsolipsism", tooltip="The bad-explanation argument against solipsism — it reconstructs realism and adds only surplus", URL="../web/arguments/deutsch-anti-solipsism.md"];
  "argument-explanatory-gap" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="explanatory gap", tooltip="The explanatory gap is evidence against uniform substrate-independence", URL="../web/arguments/explanatory-gap.md"];
  "argument-fading-qualia" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="fading qualia", tooltip="Fading qualia — a part-silicon functional isomorph cannot have faded experience without being radically wrong about it", URL="../web/arguments/fading-qualia.md"];
  "argument-feel-is-the-watching-not-an-unwatched-difference" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="feel is the\nwatching not an\nunwatched\ndifference", tooltip="The \"real feel\" is first-person observed, not unobservable — the idleness charge presupposes that observation is third-person observation", URL="../web/arguments/feel-is-the-watching-not-an-unwatched-difference.md"];
  "argument-finite-self-model-incomplete" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="finite self model\nincomplete", tooltip="A finite system cannot completely represent its own current state (a capacity bound)", URL="../web/arguments/finite-self-model-incomplete.md"];
  "argument-first-person-access" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="first person\naccess", tooltip="First-person access to my own suffering grounds a moral-status asymmetry", URL="../web/arguments/first-person-access.md"];
  "argument-gap-deflated-by-phenomenal-concepts" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="gap deflated by\nphenomenal\nconcepts", tooltip="The explanatory gap is predicted by strong functionalism (phenomenal concepts + dancing-qualia)", URL="../web/arguments/gap-deflated-by-phenomenal-concepts.md"];
  "argument-genetic-panpsychism" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="genetic\npanpsychism", tooltip="The genetic argument — physicalism plus realism about experience entails panpsychism", URL="../web/arguments/genetic-panpsychism.md"];
  "argument-halting-oracle-unrealizable" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="halting oracle\nunrealizable", tooltip="The halting oracle is coherent yet physically unrealizable", URL="../web/arguments/halting-oracle-unrealizable.md"];
  "argument-indexical-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="indexical reply", tooltip="The Indexical Reply — Mary learns where she is in the world, not what is in the world", URL="../web/arguments/indexical-reply.md"];
  "argument-intrinsic-nature" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="intrinsic nature", tooltip="The intrinsic-nature argument — matter's hidden categorical nature is experiential", URL="../web/arguments/intrinsic-nature.md"];
  "argument-introspective-gap-from-internal-limits" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="introspective gap\nfrom internal\nlimits", tooltip="A self-explanatory gap follows from limited internal access plus non-traversable self-explanation", URL="../web/arguments/introspective-gap-from-internal-limits.md"];
  "argument-intuition-domain-asymmetry" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="intuition domain\nasymmetry", tooltip="The intuition-domain asymmetry — the cosmic table is a far extrapolation, the brain-scale isomorph a near neighbour", URL="../web/arguments/intuition-domain-asymmetry.md"];
  "argument-knowledge-argument" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="knowledge argument", tooltip="The Knowledge Argument — Mary learns a fact the physical description omits", URL="../web/arguments/knowledge-argument.md"];
  "argument-llm-representations-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="llm\nrepresentations\nreply", tooltip="The LLM-representations reply — actual text-trained models build human-aligned representations, pressing A3 empirically", URL="../web/arguments/llm-representations-reply.md"];
  "argument-llmary-token-encounter" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="llmary token\nencounter", tooltip="LLMary — a model that has read all of AI but never seen token 123 updates on first encounter, yet the whole episode is physical, refuting the Knowledge Argument's conditional", URL="../web/arguments/llmary-token-encounter.md"];
  "argument-lookup-table-combinatorial-impossibility" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="lookup table\ncombinatorial\nimpossibility", tooltip="The combinatorial-impossibility reply — a finite lookup table cannot match an open-ended mind's behaviour", URL="../web/arguments/lookup-table-combinatorial-impossibility.md"];
  "argument-lookup-table-objection" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="lookup table\nobjection", tooltip="The lookup-table (blockhead) objection — behaviour is not sufficient for mind", URL="../web/arguments/lookup-table-objection.md"];
  "argument-lookup-table-physical-impossibility" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="lookup table\nphysical\nimpossibility", tooltip="The cosmic-size reply — a behaviour-matching lookup table is too large to physically exist", URL="../web/arguments/lookup-table-physical-impossibility.md"];
  "argument-luminous-room" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="luminous room", tooltip="The Luminous Room — Searle's anti-computation intuition is as unreliable as a 19th-century intuition that magnets can't make light", URL="../web/arguments/luminous-room.md"];
  "argument-many-mansions-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="many mansions\nreply", tooltip="The Many Mansions Reply — even if programs fail, some other artificial means could yield a mind", URL="../web/arguments/many-mansions-reply.md"];
  "argument-mary-misimagined" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="mary misimagined", tooltip="The Mary intuition misimagines the premise — \"all physical facts\" is quietly read as \"lots of facts\"", URL="../web/arguments/mary-misimagined.md"];
  "argument-mary-omniscience-unrealizable" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="mary omniscience\nunrealizable", tooltip="Mary's complete physical knowledge is unrealizable — an embedded knower cannot encode the total state that contains her", URL="../web/arguments/mary-omniscience-unrealizable.md"];
  "argument-modal-rationalism" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="modal rationalism", tooltip="Modal rationalism — ideal conceivability is a guide to possibility", URL="../web/arguments/modal-rationalism.md"];
