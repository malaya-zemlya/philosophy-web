  "argument-unwarrantable-zombie-premise" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="unwarrantable\nzombie premise", tooltip="The unwarrantable premise — the zombie argument's conceivability premise cannot be cogently asserted", URL="../web/arguments/unwarrantable-zombie-premise.md"];
  "argument-zombie-conceivability" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="zombie\nconceivability", tooltip="The zombie / conceivability argument against physicalism", URL="../web/arguments/zombie-conceivability.md"];
