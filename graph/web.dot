  "claim-counterfactual-structure-underdetermines-decomposition" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="counterfactual\nstructure\nunderdetermines\ndecomposition", tooltip="Counterfactual constraints yield non-triviality but not a unique decomposition", URL="../web/claims/counterfactual-structure-underdetermines-decomposition.md"];
  "claim-dancing-qualia-presupposes-functional-introspection" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="dancing qualia\npresupposes\nfunctional\nintrospection", tooltip="The dancing/fading-qualia reductio derives its contradiction only by presupposing functionalism about introspective judgement", URL="../web/claims/dancing-qualia-presupposes-functional-introspection.md"];
  "claim-finite-mind-truncates-beyond-capacity" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="finite mind\ntruncates beyond\ncapacity", tooltip="A finite mind also fails on inputs beyond its own capacity", URL="../web/claims/finite-mind-truncates-beyond-capacity.md"];
  "claim-finite-table-misses-inputs" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="finite table\nmisses inputs", tooltip="For any finite lookup table there are finite inputs outside its stored domain, to which it can only \"respond\" by ignoring the excess of the input", URL="../web/claims/finite-table-misses-inputs.md"];
  "claim-forgeable-sign-unfit-as-criterion" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="forgeable sign\nunfit as criterion", tooltip="A behavioural sign that is cheap to forge is unfit to serve as the criterion of moral standing", URL="../web/claims/forgeable-sign-unfit-as-criterion.md"];
  "claim-functional-decomposition-relative" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="functional\ndecomposition\nrelative", tooltip="A physical system has no unique functional decomposition", URL="../web/claims/functional-decomposition-relative.md"];
  "claim-functional-description-structural-dynamical-only" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="functional\ndescription\nstructural\ndynamical only", tooltip="A functional description captures only structural-dynamical facts, not intrinsic nature", URL="../web/claims/functional-description-structural-dynamical-only.md"];
  "claim-functionalism-owes-decomposition-invariant" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="functionalism owes\ndecomposition\ninvariant", tooltip="Functionalism owes an observer-independent invariant that fixes a system's decomposition", URL="../web/claims/functionalism-owes-decomposition-invariant.md"];
  "claim-heap-predicate-sharp" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="heap predicate\nsharp", tooltip="There is a precise grain-count at which a heap becomes a non-heap", URL="../web/claims/heap-predicate-sharp.md"];
  "claim-humans-closed-to-psychophysical-link" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="humans closed to\npsychophysical\nlink", tooltip="Humans are cognitively closed to the property that explains how the brain produces consciousness", URL="../web/claims/humans-closed-to-psychophysical-link.md"];
  "claim-imaginary-blockhead-no-secure-verdict" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="imaginary\nblockhead no\nsecure verdict", tooltip="For a merely conceivable lookup table, the intuition that it lacks a mind is not compelled", URL="../web/claims/imaginary-blockhead-no-secure-verdict.md"];
  "claim-implementation-requires-counterfactual-structure" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="implementation\nrequires\ncounterfactual\nstructure", tooltip="Implementing a computation requires the right counterfactual dispositions across the whole transition table", URL="../web/claims/implementation-requires-counterfactual-structure.md"];
