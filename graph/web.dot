  "claim-some-beliefs-are-basic" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="some beliefs are\nbasic", tooltip="Some beliefs are justified non-inferentially rather than by derivation from other beliefs", URL="../web/claims/some-beliefs-are-basic.md"];
