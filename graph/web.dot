  "argument-ability-hypothesis" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="ability hypothesis", tooltip="The Ability Hypothesis — experience teaches know-how, so Mary learns no new fact", URL="../web/arguments/ability-hypothesis.md"];
