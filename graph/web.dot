  "claim-ai-hard-problem-is-model-organism" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="ai hard problem is\nmodel organism", tooltip="The AI hard problem is a model organism for the human hard problem", URL="../web/claims/ai-hard-problem-is-model-organism.md"];
  "claim-ai-own-hard-problem" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="ai own hard\nproblem", tooltip="A sufficiently advanced LLM could exhibit its own version of the hard problem — a raw feel, under its own concept of consciousness, that mechanistic self-knowledge cannot explain from inside", URL="../web/claims/ai-own-hard-problem.md"];
  "claim-all-knowledge-is-conjectural" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="all knowledge is\nconjectural", tooltip="All knowledge is fallible conjecture, resting on no certain foundations", URL="../web/claims/all-knowledge-is-conjectural.md"];
  "claim-aposteriori-necessities-are-misdescribed-possibilities" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="aposteriori\nnecessities are\nmisdescribed\npossibilities", tooltip="Kripkean a-posteriori necessities are misdescribed genuine possibilities, not conceived impossibilities", URL="../web/claims/aposteriori-necessities-are-misdescribed-possibilities.md"];
  "claim-apriori-anthropomorphism-circular" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="apriori\nanthropomorphism\ncircular", tooltip="Assuming anthropomorphic attributes a priori, independent of substrate, yields circular or uninformative conclusions", URL="../web/claims/apriori-anthropomorphism-circular.md"];
  "claim-behaviour-insufficient-for-mind" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="behaviour\ninsufficient for\nmind", tooltip="Matching the full behavioural profile of a mental state is not sufficient for having that state", URL="../web/claims/behaviour-insufficient-for-mind.md"];
  "claim-biology-currently-unforgeable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="biology currently\nunforgeable", tooltip="Biological substrate cannot currently be counterfeited to the standard required to fake suffering", URL="../web/claims/biology-currently-unforgeable.md"];
  "claim-blind-spot-and-conscious-hard-problem-isomorphic" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="blind spot and\nconscious hard\nproblem isomorphic", tooltip="An AI's blind-spot hard problem is structurally isomorphic to a conscious AI's hard problem", URL="../web/claims/blind-spot-and-conscious-hard-problem-isomorphic.md"];
  "claim-blockhead-deflation-targeted-not-global" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="blockhead\ndeflation targeted\nnot global", tooltip="Deflating the cosmic-table intuition does not deflate intuitions about brain-scale duplicates", URL="../web/claims/blockhead-deflation-targeted-not-global.md"];
  "claim-brains-cause-minds" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="brains cause minds", tooltip="Brains cause minds through their specific biological causal powers", URL="../web/claims/brains-cause-minds.md"];
  "claim-causal-structure-fixes-decomposition" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="causal structure\nfixes\ndecomposition", tooltip="Objective causal structure singles out a privileged functional decomposition", URL="../web/claims/causal-structure-fixes-decomposition.md"];
  "claim-chinese-nation-lacks-qualia" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="chinese nation\nlacks qualia", tooltip="A population realising a mind's functional organisation would nonetheless have no phenomenal consciousness", URL="../web/claims/chinese-nation-lacks-qualia.md"];
  "claim-chinese-nation-realises-organisation" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="chinese nation\nrealises\norganisation", tooltip="A population can realise a mind's full functional-causal organisation, not merely its input-output behaviour", URL="../web/claims/chinese-nation-realises-organisation.md"];
  "claim-chinese-room-no-understanding" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="chinese room no\nunderstanding", tooltip="The person executing the Chinese Room program understands no Chinese", URL="../web/claims/chinese-room-no-understanding.md"];
  "claim-chinese-room-runs-program" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="chinese room runs\nprogram", tooltip="A person who understands no Chinese can, by executing a formal program, produce responses indistinguishable from a Chinese speaker's", URL="../web/claims/chinese-room-runs-program.md"];
  "claim-closing-access-gap-leaves-phenomenal-open" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="closing access gap\nleaves phenomenal\nopen", tooltip="Removing a system's access barriers to self-explanation need not remove the phenomenal explanatory gap", URL="../web/claims/closing-access-gap-leaves-phenomenal-open.md"];
  "claim-cogency-requires-accessible-noncircular-warrant" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="cogency requires\naccessible\nnoncircular\nwarrant", tooltip="Dialectical cogency requires premises with accessible, non-question-begging justification", URL="../web/claims/cogency-requires-accessible-noncircular-warrant.md"];
  "claim-cognitive-closure-exists" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="cognitive closure\nexists", tooltip="A type of mind can be constitutively incapable of grasping some concepts", URL="../web/claims/cognitive-closure-exists.md"];
  "claim-complete-self-representation-impossible" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="complete self\nrepresentation\nimpossible", tooltip="No finite system can losslessly represent its entire current state within itself", URL="../web/claims/complete-self-representation-impossible.md"];
  "claim-conceivability-entails-possibility" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="conceivability\nentails\npossibility", tooltip="Ideal conceivability entails metaphysical possibility", URL="../web/claims/conceivability-entails-possibility.md"];
  "claim-conceivability-not-sufficient-for-physical-realizability" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="conceivability not\nsufficient for\nphysical\nrealizability", tooltip="Conceivability does not entail physical realizability", URL="../web/claims/conceivability-not-sufficient-for-physical-realizability.md"];
  "claim-consciousness-categorical-not-dispositional" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness\ncategorical not\ndispositional", tooltip="Phenomenal consciousness is categorical, not merely dispositional", URL="../web/claims/consciousness-categorical-not-dispositional.md"];
  "claim-consciousness-fundamental-nonphysical" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness\nfundamental\nnonphysical", tooltip="Phenomenal consciousness is a fundamental, non-physical feature of reality", URL="../web/claims/consciousness-fundamental-nonphysical.md"];
  "claim-consciousness-fundamental-ubiquitous" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness\nfundamental\nubiquitous", tooltip="Consciousness is fundamental, present even in the simplest physical entities", URL="../web/claims/consciousness-fundamental-ubiquitous.md"];
  "claim-consciousness-has-natural-explanation" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness has\nnatural\nexplanation", tooltip="There is a natural property of the brain that explains consciousness", URL="../web/claims/consciousness-has-natural-explanation.md"];
  "claim-consciousness-is-biological-feature" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness is\nbiological feature", tooltip="Consciousness is a higher-level feature caused by neurobiological processes", URL="../web/claims/consciousness-is-biological-feature.md"];
  "claim-consciousness-is-global-broadcast" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness is\nglobal broadcast", tooltip="A state is conscious only if its content is globally broadcast to the brain's specialist systems", URL="../web/claims/consciousness-is-global-broadcast.md"];
  "claim-consciousness-is-higher-order-representation" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness is\nhigher order\nrepresentation", tooltip="A mental state is conscious only if it is the object of a higher-order representation", URL="../web/claims/consciousness-is-higher-order-representation.md"];
  "claim-consciousness-is-integrated-information" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness is\nintegrated\ninformation", tooltip="Consciousness is identical to a system's integrated information (Φ)", URL="../web/claims/consciousness-is-integrated-information.md"];
  "claim-consciousness-is-intrinsic-property" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness is\nintrinsic property", tooltip="Consciousness is an intrinsic property of whatever has it", URL="../web/claims/consciousness-is-intrinsic-property.md"];
  "claim-consciousness-noncomputable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness\nnoncomputable", tooltip="Consciousness involves non-computable physical processes", URL="../web/claims/consciousness-noncomputable.md"];
  "claim-consciousness-only-known-intrinsic" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness only\nknown intrinsic", tooltip="Consciousness is the only intrinsic nature we are directly acquainted with", URL="../web/claims/consciousness-only-known-intrinsic.md"];
  "claim-consistency-certification-is-oracle-hard" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consistency\ncertification is\noracle hard", tooltip="Reliably certifying the consistency of arithmetic-rich scenarios is at least as hard as the halting problem", URL="../web/claims/consistency-certification-is-oracle-hard.md"];
  "claim-cosmos-is-fundamental-subject" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="cosmos is\nfundamental\nsubject", tooltip="The universe as a whole is the one fundamental conscious subject", URL="../web/claims/cosmos-is-fundamental-subject.md"];
  "claim-counterfactual-structure-objective" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="counterfactual\nstructure\nobjective", tooltip="Counterfactual-causal dependencies are objective, not observer-relative", URL="../web/claims/counterfactual-structure-objective.md"];
  "claim-counterfactual-structure-underdetermines-decomposition" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="counterfactual\nstructure\nunderdetermines\ndecomposition", tooltip="Counterfactual constraints yield non-triviality but not a unique decomposition", URL="../web/claims/counterfactual-structure-underdetermines-decomposition.md"];
  "claim-dancing-qualia-presupposes-functional-introspection" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="dancing qualia\npresupposes\nfunctional\nintrospection", tooltip="The dancing/fading-qualia reductio derives its contradiction only by presupposing functionalism about introspective judgement", URL="../web/claims/dancing-qualia-presupposes-functional-introspection.md"];
  "claim-explanation-must-be-internally-traversable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="explanation must\nbe internally\ntraversable", tooltip="An explanation is intuitively satisfying for a system only if it is traversable by that system's own cognitive operations", URL="../web/claims/explanation-must-be-internally-traversable.md"];
  "claim-external-world-exists" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="external world\nexists", tooltip="A mind-independent external world exists", URL="../web/claims/external-world-exists.md"];
  "claim-external-world-unprovable-noncircular" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="external world\nunprovable\nnoncircular", tooltip="The existence of the external world cannot be demonstrated without circularity", URL="../web/claims/external-world-unprovable-noncircular.md"];
  "claim-finite-mind-truncates-beyond-capacity" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="finite mind\ntruncates beyond\ncapacity", tooltip="A finite mind also fails on inputs beyond its own capacity", URL="../web/claims/finite-mind-truncates-beyond-capacity.md"];
  "claim-finite-table-misses-inputs" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="finite table\nmisses inputs", tooltip="For any finite lookup table there are finite inputs outside its stored domain, to which it can only \"respond\" by ignoring the excess of the input", URL="../web/claims/finite-table-misses-inputs.md"];
  "claim-folk-psychology-is-false-theory" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="folk psychology is\nfalse theory", tooltip="Folk-psychological mental states are posits of a false theory", URL="../web/claims/folk-psychology-is-false-theory.md"];
  "claim-forgeable-sign-unfit-as-criterion" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="forgeable sign\nunfit as criterion", tooltip="A behavioural sign that is cheap to forge is unfit to serve as the criterion of moral standing", URL="../web/claims/forgeable-sign-unfit-as-criterion.md"];
  "claim-full-self-access-achievable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="full self access\nachievable", tooltip="A finite system can be given complete internal access to its own current state", URL="../web/claims/full-self-access-achievable.md"];
  "claim-functional-decomposition-relative" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="functional\ndecomposition\nrelative", tooltip="A physical system has no unique functional decomposition", URL="../web/claims/functional-decomposition-relative.md"];
  "claim-functional-description-structural-dynamical-only" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="functional\ndescription\nstructural\ndynamical only", tooltip="A functional description captures only structural-dynamical facts, not intrinsic nature", URL="../web/claims/functional-description-structural-dynamical-only.md"];
  "claim-functionalism-owes-decomposition-invariant" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="functionalism owes\ndecomposition\ninvariant", tooltip="Functionalism owes an observer-independent invariant that fixes a system's decomposition", URL="../web/claims/functionalism-owes-decomposition-invariant.md"];
  "claim-gap-persistence-cannot-separate-blind-spot-from-consciousness" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="gap persistence\ncannot separate\nblind spot from\nconsciousness", tooltip="Persistence of an AI's explanatory gap under widening self-access cannot discriminate a structural blind spot from consciousness", URL="../web/claims/gap-persistence-cannot-separate-blind-spot-from-consciousness.md"];
  "claim-good-explanation-is-hard-to-vary" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="good explanation\nis hard to vary", tooltip="A good explanation is one that is hard to vary while still accounting for what it explains", URL="../web/claims/good-explanation-is-hard-to-vary.md"];
  "claim-halting-oracle-coherent-but-unrealizable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="halting oracle\ncoherent but\nunrealizable", tooltip="The halting oracle is mathematically coherent yet physically unrealizable", URL="../web/claims/halting-oracle-coherent-but-unrealizable.md"];
  "claim-halting-problem-undecidable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="halting problem\nundecidable", tooltip="No Turing machine decides the halting problem", URL="../web/claims/halting-problem-undecidable.md"];
  "claim-hard-problem-conceived-de-novo-by-humans" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="hard problem\nconceived de novo\nby humans", tooltip="Humans originated the hard-problem concept de novo, with no prior template to copy", URL="../web/claims/hard-problem-conceived-de-novo-by-humans.md"];
  "claim-heap-predicate-sharp" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="heap predicate\nsharp", tooltip="There is a precise grain-count at which a heap becomes a non-heap", URL="../web/claims/heap-predicate-sharp.md"];
  "claim-humans-closed-to-psychophysical-link" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="humans closed to\npsychophysical\nlink", tooltip="Humans are cognitively closed to the property that explains how the brain produces consciousness", URL="../web/claims/humans-closed-to-psychophysical-link.md"];
  "claim-ideal-conceivability-is-apriori-consistency" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="ideal\nconceivability is\napriori\nconsistency", tooltip="A scenario's ideal conceivability is its consistency under ideal a priori reasoning", URL="../web/claims/ideal-conceivability-is-apriori-consistency.md"];
  "claim-imaginary-blockhead-no-secure-verdict" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="imaginary\nblockhead no\nsecure verdict", tooltip="For a merely conceivable lookup table, the intuition that it lacks a mind is not compelled", URL="../web/claims/imaginary-blockhead-no-secure-verdict.md"];
  "claim-implementation-requires-counterfactual-structure" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="implementation\nrequires\ncounterfactual\nstructure", tooltip="Implementing a computation requires the right counterfactual dispositions across the whole transition table", URL="../web/claims/implementation-requires-counterfactual-structure.md"];
  "claim-inside-vantage-access-limited" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="inside vantage\naccess limited", tooltip="A system's internal vantage on itself is informationally poorer than an external vantage", URL="../web/claims/inside-vantage-access-limited.md"];
  "claim-intuition-warrant-tracks-trained-domain" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="intuition warrant\ntracks trained\ndomain", tooltip="An intuition's evidential weight tracks the case's resemblance to the exemplars it was formed on", URL="../web/claims/intuition-warrant-tracks-trained-domain.md"];
  "claim-irreducible-mental-causally-excluded" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="irreducible mental\ncausally excluded", tooltip="A mental property that supervenes on but is not identical to its physical base is causally excluded by that base", URL="../web/claims/irreducible-mental-causally-excluded.md"];
  "claim-justification-is-infinite-chain" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="justification is\ninfinite chain", tooltip="Justification consists in an infinite, non-repeating chain of reasons", URL="../web/claims/justification-is-infinite-chain.md"];
  "claim-justification-is-mutual-support" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="justification is\nmutual support", tooltip="Justification is the mutual support of beliefs within a system, not a linear chain from foundations", URL="../web/claims/justification-is-mutual-support.md"];
  "claim-justification-terminates-in-trilemma" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="justification\nterminates in\ntrilemma", tooltip="Every attempt at complete justification ends in regress, circularity, or a dogmatic stopping point", URL="../web/claims/justification-terminates-in-trilemma.md"];
  "claim-knowhow-is-knowledge-that" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="knowhow is\nknowledge that", tooltip="Knowing how to do something is a species of propositional knowledge", URL="../web/claims/knowhow-is-knowledge-that.md"];
  "claim-knowledge-without-noncircular-proof" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="knowledge without\nnoncircular proof", tooltip="One can know a proposition without being able to demonstrate it non-circularly", URL="../web/claims/knowledge-without-noncircular-proof.md"];
  "claim-lifetime-bounded-table-covers-encountered-inputs" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lifetime bounded\ntable covers\nencountered inputs", tooltip="A lookup table can be bounded to cover every input a subject encounters in a lifetime", URL="../web/claims/lifetime-bounded-table-covers-encountered-inputs.md"];
  "claim-llm-access-similarity-not-encoding" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm access\nsimilarity not\nencoding", tooltip="An LLM's introspective access reaches the similarity structure of its internal states but not the encoding that carries it", URL="../web/claims/llm-access-similarity-not-encoding.md"];
  "claim-llm-approximates-perfect-actor" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm approximates\nperfect actor", tooltip="Large language models are an actual-world approximation of the perfect actor", URL="../web/claims/llm-approximates-perfect-actor.md"];
  "claim-llm-attributes-empirically-non-unique" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm attributes\nempirically non\nunique", tooltip="The anthropomorphic attributes ascribed to LLMs are empirically non-unique across substrates", URL="../web/claims/llm-attributes-empirically-non-unique.md"];
  "claim-llm-functional-introspection" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm functional\nintrospection", tooltip="Some current LLMs exhibit limited, unreliable functional introspective awareness of their internal states", URL="../web/claims/llm-functional-introspection.md"];
  "claim-llm-has-mental-states" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm has mental\nstates", tooltip="Some current LLMs realise some mental states", URL="../web/claims/llm-has-mental-states.md"];
  "claim-llm-text-yields-human-aligned-representations" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="llm text yields\nhuman aligned\nrepresentations", tooltip="Language models trained on text alone develop internal representations structurally aligned with human ones", URL="../web/claims/llm-text-yields-human-aligned-representations.md"];
  "claim-lookup-table-combinatorially-inadequate" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table\ncombinatorially\ninadequate", tooltip="No finite lookup table can reproduce the full behavioural profile of a genuine mind", URL="../web/claims/lookup-table-combinatorially-inadequate.md"];
  "claim-lookup-table-lacks-mind" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table lacks\nmind", tooltip="A system that produces behaviour solely by stored lookup has no mental states", URL="../web/claims/lookup-table-lacks-mind.md"];
  "claim-lookup-table-physically-unrealisable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table\nphysically\nunrealisable", tooltip="A lookup table reproducing a human- or LLM-scale behavioural profile is physically unrealisable", URL="../web/claims/lookup-table-physically-unrealisable.md"];
  "claim-lookup-table-possible" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table\npossible", tooltip="A lookup table can reproduce a mind's behavioural profile without any internal causal organisation", URL="../web/claims/lookup-table-possible.md"];
  "claim-lookup-table-size-exponential" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="lookup table size\nexponential", tooltip="A lookup table reproducing behaviour over a context of n tokens from a vocabulary of v requires on the order of v^n entries", URL="../web/claims/lookup-table-size-exponential.md"];
  "claim-mary-gains-abilities-not-facts" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary gains\nabilities not\nfacts", tooltip="What Mary acquires on first seeing red is a set of abilities, not knowledge of a new fact", URL="../web/claims/mary-gains-abilities-not-facts.md"];
  "claim-mary-gains-acquaintance" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary gains\nacquaintance", tooltip="What Mary acquires on first seeing red is acquaintance with the experience, not knowledge of a new fact", URL="../web/claims/mary-gains-acquaintance.md"];
  "claim-mary-gains-old-fact-new-guise" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary gains old\nfact new guise", tooltip="What Mary acquires on first seeing red is a new phenomenal concept of a physical fact she already knew", URL="../web/claims/mary-gains-old-fact-new-guise.md"];
  "claim-mary-gains-self-locating-knowledge" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary gains self\nlocating knowledge", tooltip="What Mary acquires on first seeing red is self-locating knowledge of how she herself reacts to red, not a new general fact", URL="../web/claims/mary-gains-self-locating-knowledge.md"];
  "claim-mary-knows-all-physical" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary knows all\nphysical", tooltip="Before leaving the room, Mary knows all the physical facts about colour vision", URL="../web/claims/mary-knows-all-physical.md"];
  "claim-mary-learns-nothing-new" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary learns\nnothing new", tooltip="Mary, genuinely knowing all the physical facts, would learn nothing on first seeing red", URL="../web/claims/mary-learns-nothing-new.md"];
  "claim-mary-learns-on-release" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mary learns on\nrelease", tooltip="On first seeing red, Mary learns something she did not know before", URL="../web/claims/mary-learns-on-release.md"];
  "claim-mental-events-have-physical-effects" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mental events have\nphysical effects", tooltip="Some mental events cause physical effects", URL="../web/claims/mental-events-have-physical-effects.md"];
  "claim-mental-is-physical" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mental is physical", tooltip="Mental events are physical events", URL="../web/claims/mental-is-physical.md"];
  "claim-mental-states-are-brain-state-types" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mental states are\nbrain state types", tooltip="Each type of mental state is identical to a type of brain state", URL="../web/claims/mental-states-are-brain-state-types.md"];
  "claim-mental-states-causally-inert" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mental states\ncausally inert", tooltip="Phenomenal mental states are caused by physical processes but have no physical effects", URL="../web/claims/mental-states-causally-inert.md"];
  "claim-micro-subjects-do-not-sum" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="micro subjects do\nnot sum", tooltip="Distinct micro-subjects cannot sum into a further macro-subject", URL="../web/claims/micro-subjects-do-not-sum.md"];
  "claim-mind-handles-unbounded-inputs" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="mind handles\nunbounded inputs", tooltip="A genuine mind can respond appropriately to novel inputs beyond any fixed finite stock", URL="../web/claims/mind-handles-unbounded-inputs.md"];
  "claim-minds-have-semantics" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="minds have\nsemantics", tooltip="Minds have semantic content (genuine meaning), not merely syntax", URL="../web/claims/minds-have-semantics.md"];
  "claim-no-acquaintance-with-machine" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="no acquaintance\nwith machine", tooltip="One has no first-person acquaintance with a machine's putative experience", URL="../web/claims/no-acquaintance-with-machine.md"];
  "claim-no-nonarbitrary-threshold-for-experience" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="no nonarbitrary\nthreshold for\nexperience", tooltip="There is no non-arbitrary point in nature at which experience first appears", URL="../web/claims/no-nonarbitrary-threshold-for-experience.md"];
  "claim-no-radical-emergence" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="no radical\nemergence", tooltip="Experience cannot emerge brutely from the wholly non-experiential", URL="../web/claims/no-radical-emergence.md"];
  "claim-no-systematic-overdetermination" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="no systematic\noverdetermination", tooltip="The physical effects of mental causes are not systematically overdetermined", URL="../web/claims/no-systematic-overdetermination.md"];
  "claim-observable-universe-finite-storage" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="observable\nuniverse finite\nstorage", tooltip="The observable universe can store only a bounded, finite amount of information (on the order of 10^120 bits)", URL="../web/claims/observable-universe-finite-storage.md"];
  "claim-organisational-grain-faces-own-grain-dilemma" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="organisational\ngrain faces own\ngrain dilemma", tooltip="The organisational-role grain either readmits the blockhead or smuggles sub-organisational features back in", URL="../web/claims/organisational-grain-faces-own-grain-dilemma.md"];
  "claim-organizational-invariance" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="organizational\ninvariance", tooltip="Systems with the same fine-grained functional organization have qualitatively identical experiences", URL="../web/claims/organizational-invariance.md"];
  "claim-perceptron-realizable-in-any-substrate" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="perceptron\nrealizable in any\nsubstrate", tooltip="A trainable neural network can be realized in any sufficiently powerful substrate", URL="../web/claims/perceptron-realizable-in-any-substrate.md"];
  "claim-personal-identity-admits-of-degree" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="personal identity\nadmits of degree", tooltip="Personal identity is not all-or-nothing but admits of degree", URL="../web/claims/personal-identity-admits-of-degree.md"];
  "claim-phenomenal-character-is-representational" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal\ncharacter is\nrepresentational", tooltip="Phenomenal character is identical to representational content", URL="../web/claims/phenomenal-character-is-representational.md"];
  "claim-phenomenal-concept-isolation-tradeoff" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal concept\nisolation tradeoff", tooltip="A phenomenal concept cannot be at once informative enough to ground self-knowledge while isolated enough to deflate the explanatory gap", URL="../web/claims/phenomenal-concept-isolation-tradeoff.md"];
  "claim-phenomenal-consciousness-is-real" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal\nconsciousness is\nreal", tooltip="Phenomenal consciousness is genuinely real, not an illusion", URL="../web/claims/phenomenal-consciousness-is-real.md"];
  "claim-phenomenal-determinacy" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal\ndeterminacy", tooltip="There is a determinate fact about one's own current phenomenal state", URL="../web/claims/phenomenal-determinacy.md"];
  "claim-phenomenal-intensions-coincide" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal\nintensions\ncoincide", tooltip="For phenomenal concepts, the two intensions coincide", URL="../web/claims/phenomenal-intensions-coincide.md"];
  "claim-phenomenal-residue" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenal residue", tooltip="Phenomenally conscious states are not exhausted by functional/causal role", URL="../web/claims/phenomenal-states-not-exhausted-by-role.md"];
  "claim-phenomenality-is-illusion" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="phenomenality is\nillusion", tooltip="Phenomenal consciousness as standardly conceived is an introspective illusion", URL="../web/claims/phenomenality-is-illusion.md"];
  "claim-physical-church-turing-thesis" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="physical church\nturing thesis", tooltip="Every physically realizable computation is Turing-computable", URL="../web/claims/physical-church-turing-thesis.md"];
  "claim-physical-domain-complete" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="physical domain\ncomplete", tooltip="Every physical effect has a sufficient physical cause", URL="../web/claims/physical-domain-complete.md"];
  "claim-physics-delivers-all-dispositions-indiscriminately" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="physics delivers\nall dispositions\nindiscriminately", tooltip="The physical facts about a system include every causal disposition, not only the cognitively relevant ones", URL="../web/claims/physics-delivers-all-dispositions-indiscriminately.md"];
  "claim-posing-the-gap-requires-access" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="posing the gap\nrequires access", tooltip="Formulating the hard problem from the first-person side requires access to a representation of one's own phenomenal-seeming states", URL="../web/claims/posing-the-gap-requires-access.md"];
  "claim-privileged-first-person-access" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="privileged first\nperson access", tooltip="Each subject has direct, non-inferential first-person acquaintance with its own conscious states", URL="../web/claims/privileged-first-person-access.md"];
  "claim-programs-are-syntactic" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="programs are\nsyntactic", tooltip="Computer programs are purely formal (syntactic)", URL="../web/claims/programs-are-syntactic.md"];
  "claim-programs-not-sufficient-for-minds" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="programs not\nsufficient for\nminds", tooltip="Implementing a program is neither constitutive of nor sufficient for having a mind", URL="../web/claims/programs-not-sufficient-for-minds.md"];
  "claim-prudence-favors-flesh-criterion" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="prudence favors\nflesh criterion", tooltip="Prudence favours resting moral standing on currently-unforgeable biology rather than on forgeable behavioural signs", URL="../web/claims/prudence-favors-flesh-criterion.md"];
  "claim-prudence-tracks-unforgeability-not-flesh" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="prudence tracks\nunforgeability not\nflesh", tooltip="What prudence favours is the hardest-to-forge sign, not biology specifically", URL="../web/claims/prudence-tracks-unforgeability-not-flesh.md"];
  "claim-psychological-rewiring-tolerance" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="psychological\nrewiring tolerance", tooltip="Altering a single psychological connection never changes who someone is", URL="../web/claims/psychological-rewiring-tolerance.md"];
  "claim-realisable-behaviour-matcher-is-organised" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="realisable\nbehaviour matcher\nis organised", tooltip="Any physically realisable behaviour-matcher is an organised computer, not flat storage", URL="../web/claims/realisable-behaviour-matcher-is-organised.md"];
  "claim-reality-fundamental-stuff-neutral" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="reality\nfundamental stuff\nneutral", tooltip="Reality's fundamental constituents are neither mental nor physical", URL="../web/claims/reality-fundamental-stuff-neutral.md"];
  "claim-reality-is-fundamentally-mental" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="reality is\nfundamentally\nmental", tooltip="Reality is fundamentally mental", URL="../web/claims/reality-is-fundamentally-mental.md"];
  "claim-reality-two-aspects-mental-physical" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="reality two\naspects mental\nphysical", tooltip="Reality has two irreducible aspects, the mental as well as the physical", URL="../web/claims/reality-two-aspects-mental-physical.md"];
  "claim-relations-grounded-in-intrinsic" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="relations grounded\nin intrinsic", tooltip="A thing's relational-structural properties must be grounded in its intrinsic nature", URL="../web/claims/relations-grounded-in-intrinsic.md"];
  "claim-rights-criterion-will-be-gamed" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="rights criterion\nwill be gamed", tooltip="Any behavioural sign adopted as the public criterion for granting rights will be optimized against until it no longer tracks the underlying state", URL="../web/claims/rights-criterion-will-be-gamed.md"];
  "claim-role-grain-is-organisational" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="role grain is\norganisational", tooltip="The mind-individuating functional role is fixed at the grain of internal counterfactual-causal organisation", URL="../web/claims/role-grain-is-organisational.md"];
