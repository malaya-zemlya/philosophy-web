  "argument-munchhausen-trilemma" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="munchhausen\ntrilemma", tooltip="The regress argument — complete justification must regress, circle, or break off", URL="../web/arguments/munchhausen-trilemma.md"];
  "argument-no-arbitrary-line-panpsychism" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="no arbitrary line\npanpsychism", tooltip="The continuity argument — no non-arbitrary line where experience switches on", URL="../web/arguments/no-arbitrary-line-panpsychism.md"];
  "argument-old-fact-new-guise" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="old fact new guise", tooltip="Old fact, new guise — Mary's new knowledge is a new phenomenal concept, not a new fact", URL="../web/arguments/old-fact-new-guise.md"];
  "argument-organisational-grain-dissolves-dilemma" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="organisational\ngrain dissolves\ndilemma", tooltip="The organisational grain is a principled middle that escapes both horns of the grain dilemma", URL="../web/arguments/organisational-grain-dissolves-dilemma.md"];
  "argument-other-minds-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="other minds reply", tooltip="The Other Minds Reply — we attribute understanding to others on behavioural grounds, so deny it to the room only by a double standard", URL="../web/arguments/other-minds-reply.md"];
  "argument-parfit-rewiring" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="parfit rewiring", tooltip="Gradual psychological rewiring (Parfit's spectrum) forces identity to admit of degree", URL="../web/arguments/parfit-rewiring.md"];
  "argument-phenomenal-concept-overgeneration" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="phenomenal concept\novergeneration", tooltip="The phenomenal-concept strategy over-generates — it debunks the self-knowledge it presupposes", URL="../web/arguments/phenomenal-concept-overgeneration.md"];
