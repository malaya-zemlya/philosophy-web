  "argument-sorites-paradox" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="sorites paradox", tooltip="The sorites paradox (the heap)", URL="../web/arguments/sorites-paradox.md"];
  "argument-storage-not-stable-kind" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="storage not stable\nkind", tooltip="Pure storage is not a stable kind at mind-matching scale", URL="../web/arguments/storage-not-stable-kind.md"];
  "argument-storm-analogy-conflates-world-index" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="storm analogy\nconflates world\nindex", tooltip="The \"simulated storm isn't wet\" analogy conflates world-indices and the physical/phenomenal senses of wetness, so it cannot settle machine consciousness", URL="../web/arguments/storm-analogy-conflates-world-index.md"];
  "argument-strong-emergence-acceptable" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="strong emergence\nacceptable", tooltip="The emergence reply — experience can strongly emerge, so no need for fundamental mind", URL="../web/arguments/strong-emergence-acceptable.md"];
  "argument-structure-and-dynamics" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="structure and\ndynamics", tooltip="The structure-and-dynamics argument — function omits the categorical/intrinsic", URL="../web/arguments/structure-and-dynamics.md"];
  "argument-subjects-can-combine" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="subjects can\ncombine", tooltip="Subjects can combine — observed merging and a graded subject-count answer the combination problem", URL="../web/arguments/subjects-can-combine.md"];
  "argument-systems-reply" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="systems reply", tooltip="The Systems Reply — the whole system understands, though the person does not", URL="../web/arguments/systems-reply.md"];
