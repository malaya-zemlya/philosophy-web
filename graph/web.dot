digraph web {
  rankdir=LR;
  graph [overlap=prism, sep="+8", splines=true, nodesep=0.35, ranksep=0.7, fontname="Helvetica", bgcolor="white"];
  node  [fontname="Helvetica", fontsize=10];
  edge  [fontname="Helvetica", fontsize=8, arrowsize=0.7];

  "argument-access-symmetry-rebuttal" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="access symmetry\nrebuttal", tooltip="The access asymmetry is unavailable because first-person access is reciprocally non-transferable", URL="../web/arguments/access-symmetry-rebuttal.md"];
  "argument-behavioral-parity" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="behavioral parity", tooltip="Behavioural parity is evidence of mental status", URL="../web/arguments/behavioral-parity.md"];
  "argument-blockhead-dilemma" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="blockhead dilemma", tooltip="The blockhead dilemma — physically impossible, or imaginatively under-determined", URL="../web/arguments/blockhead-dilemma.md"];
  "argument-bounded-table-rejoinder" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="bounded table\nrejoinder", tooltip="Block's bounded-table rejoinder — a lifetime-bounded table escapes the combinatorial reply", URL="../web/arguments/bounded-table-rejoinder.md"];
  "argument-causal-structure-supplies-invariant" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="causal structure\nsupplies invariant", tooltip="The causal-structure reply — objective counterfactual structure supplies the invariant", URL="../web/arguments/causal-structure-supplies-invariant.md"];
  "argument-china-nation-absent-qualia" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="china nation\nabsent qualia", tooltip="The Chinese Nation realises the organisation yet lacks qualia — organisation is not sufficient for consciousness", URL="../web/arguments/china-nation-absent-qualia.md"];
  "argument-cognitive-closure" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="cognitive closure", tooltip="McGinn's cognitive-closure argument for mysterianism", URL="../web/arguments/cognitive-closure.md"];
  "argument-counterfactuals-yield-non-triviality-not-uniqueness" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="counterfactuals\nyield non\ntriviality not\nuniqueness", tooltip="Counterfactuals buy non-triviality, not uniqueness", URL="../web/arguments/counterfactuals-yield-non-triviality-not-uniqueness.md"];
  "argument-dancing-qualia-begs-the-question" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="dancing qualia\nbegs the question", tooltip="The dancing/fading-qualia reductio begs the question by presupposing functionalism about introspection", URL="../web/arguments/dancing-qualia-begs-the-question.md"];
  "argument-decomposition-indeterminacy" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="decomposition\nindeterminacy", tooltip="The decomposition-indeterminacy objection — determinate consciousness cannot rest on observer-relative function", URL="../web/arguments/decomposition-indeterminacy.md"];
  "argument-dense-china-brain-regress" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="dense china brain\nregress", tooltip="The dense China-brain regress reopens the grain dilemma against the organisational middle", URL="../web/arguments/dense-china-brain-regress.md"];
  "argument-explanatory-gap" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="explanatory gap", tooltip="The explanatory gap is evidence against uniform substrate-independence", URL="../web/arguments/explanatory-gap.md"];
  "argument-first-person-access" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="first person\naccess", tooltip="First-person access to my own suffering grounds a moral-status asymmetry", URL="../web/arguments/first-person-access.md"];
  "argument-gap-deflated-by-phenomenal-concepts" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="gap deflated by\nphenomenal\nconcepts", tooltip="The explanatory gap is predicted by strong functionalism (phenomenal concepts + dancing-qualia)", URL="../web/arguments/gap-deflated-by-phenomenal-concepts.md"];
  "argument-intuition-domain-asymmetry" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="intuition domain\nasymmetry", tooltip="The intuition-domain asymmetry — the cosmic table is a far extrapolation, the brain-scale isomorph a near neighbour", URL="../web/arguments/intuition-domain-asymmetry.md"];
  "argument-lookup-table-combinatorial-impossibility" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="lookup table\ncombinatorial\nimpossibility", tooltip="The combinatorial-impossibility reply — a finite lookup table cannot match an open-ended mind's behaviour", URL="../web/arguments/lookup-table-combinatorial-impossibility.md"];
  "argument-lookup-table-objection" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="lookup table\nobjection", tooltip="The lookup-table (blockhead) objection — behaviour is not sufficient for mind", URL="../web/arguments/lookup-table-objection.md"];
  "argument-lookup-table-physical-impossibility" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="lookup table\nphysical\nimpossibility", tooltip="The cosmic-size reply — a behaviour-matching lookup table is too large to physically exist", URL="../web/arguments/lookup-table-physical-impossibility.md"];
  "argument-organisational-grain-dissolves-dilemma" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="organisational\ngrain dissolves\ndilemma", tooltip="The organisational grain is a principled middle that escapes both horns of the grain dilemma", URL="../web/arguments/organisational-grain-dissolves-dilemma.md"];
  "argument-parfit-rewiring" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="parfit rewiring", tooltip="Gradual psychological rewiring (Parfit's spectrum) forces identity to admit of degree", URL="../web/arguments/parfit-rewiring.md"];
  "argument-phenomenal-concept-overgeneration" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="phenomenal concept\novergeneration", tooltip="The phenomenal-concept strategy over-generates — it debunks the self-knowledge it presupposes", URL="../web/arguments/phenomenal-concept-overgeneration.md"];
  "argument-relevance-filter-regress" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="relevance filter\nregress", tooltip="The relevance-filter regress — selecting mind-relevant causal relations re-raises the invariant demand", URL="../web/arguments/relevance-filter-regress.md"];
  "argument-rights-sign-forgeable" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="rights sign\nforgeable", tooltip="A rights-granting behavioural sign will be forged, so caution favours the unforgeable mark", URL="../web/arguments/rights-sign-forgeable.md"];
  "argument-role-grain-dilemma" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="role grain dilemma", tooltip="The grain dilemma for functional \"role\" (too liberal vs. too chauvinistic)", URL="../web/arguments/role-grain-dilemma.md"];
  "argument-sorites-paradox" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="sorites paradox", tooltip="The sorites paradox (the heap)", URL="../web/arguments/sorites-paradox.md"];
  "argument-storage-not-stable-kind" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="storage not stable\nkind", tooltip="Pure storage is not a stable kind at mind-matching scale", URL="../web/arguments/storage-not-stable-kind.md"];
  "argument-structure-and-dynamics" [shape="box", style="filled", fillcolor="#eeeeee", color="#888888", label="structure and\ndynamics", tooltip="The structure-and-dynamics argument — function omits the categorical/intrinsic", URL="../web/arguments/structure-and-dynamics.md"];
  "claim-access-gap-symmetric" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="access gap\nsymmetric", tooltip="The first-person/third-person access gap is symmetric across any two subjects, never singling out machines", URL="../web/claims/access-gap-symmetric.md"];
  "claim-access-grounds-moral-status-asymmetry" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="access grounds\nmoral status\nasymmetry", tooltip="First-person access yields a warranted moral-status asymmetry favouring oneself over a machine", URL="../web/claims/access-grounds-moral-status-asymmetry.md"];
  "claim-access-grounds-no-asymmetry" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="access grounds no\nasymmetry", tooltip="First-person access grounds no moral-status asymmetry that singles out machines", URL="../web/claims/access-grounds-no-asymmetry.md"];
  "claim-acquaintance-necessary-for-moral-status-warrant" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="acquaintance\nnecessary for\nmoral status\nwarrant", tooltip="First-person acquaintance with a subject's experience is necessary for justified attribution of moral status to it", URL="../web/claims/acquaintance-necessary-for-moral-status-warrant.md"];
  "claim-behaviour-insufficient-for-mind" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="behaviour\ninsufficient for\nmind", tooltip="Matching the full behavioural profile of a mental state is not sufficient for having that state", URL="../web/claims/behaviour-insufficient-for-mind.md"];
  "claim-biology-currently-unforgeable" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="biology currently\nunforgeable", tooltip="Biological substrate cannot currently be counterfeited to the standard required to fake suffering", URL="../web/claims/biology-currently-unforgeable.md"];
  "claim-blockhead-deflation-targeted-not-global" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="blockhead\ndeflation targeted\nnot global", tooltip="Deflating the cosmic-table intuition does not deflate intuitions about brain-scale duplicates", URL="../web/claims/blockhead-deflation-targeted-not-global.md"];
  "claim-causal-structure-fixes-decomposition" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="causal structure\nfixes\ndecomposition", tooltip="Objective causal structure singles out a privileged functional decomposition", URL="../web/claims/causal-structure-fixes-decomposition.md"];
  "claim-chinese-nation-lacks-qualia" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="chinese nation\nlacks qualia", tooltip="A population realising a mind's functional organisation would nonetheless have no phenomenal consciousness", URL="../web/claims/chinese-nation-lacks-qualia.md"];
  "claim-chinese-nation-realises-organisation" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="chinese nation\nrealises\norganisation", tooltip="A population can realise a mind's full functional-causal organisation, not merely its input-output behaviour", URL="../web/claims/chinese-nation-realises-organisation.md"];
  "claim-cognitive-closure-exists" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="cognitive closure\nexists", tooltip="A type of mind can be constitutively incapable of grasping some concepts", URL="../web/claims/cognitive-closure-exists.md"];
  "claim-consciousness-categorical-not-dispositional" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness\ncategorical not\ndispositional", tooltip="Phenomenal consciousness is categorical, not merely dispositional", URL="../web/claims/consciousness-categorical-not-dispositional.md"];
  "claim-consciousness-has-natural-explanation" [shape="box", style="filled,rounded", fillcolor="#cfe0f5", color="#5b8fbf", label="consciousness has\nnatural\nexplanation", tooltip="There is a natural property of the brain that explains consciousness", URL="../web/claims/consciousness-has-natural-explanation.md"];
